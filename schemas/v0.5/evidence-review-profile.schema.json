{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/guard-native-agent-harness/schemas/v0.5/evidence-review-profile.schema.json",
  "title": "Guard-native v0.5 Evidence Review Profile",
  "description": "Local deterministic review profile schema for v0.5 evidence review artifacts. Profiles are not approval, not enforcement, not autonomous execution, not a runtime control plane, and no authority grant.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "display_name",
    "description",
    "intended_context",
    "required_evidence_files",
    "expected_verifiers",
    "inspection_outputs",
    "review_sections",
    "boundary",
    "non_goals"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "guard-native-evidence-review-profile.v0.5"
    },
    "profile_id": {
      "type": "string",
      "enum": [
        "local-dev",
        "ci-pr",
        "release-prep",
        "audit-review"
      ]
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "intended_context": {
      "type": "string",
      "minLength": 1
    },
    "required_evidence_files": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_file"
      }
    },
    "expected_verifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "inspection_outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inspection_output"
      }
    },
    "review_sections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/review_section"
      }
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "approval",
        "enforcement",
        "autonomous_execution",
        "runtime_control_plane",
        "authority_grant",
        "provider_output_authorizes_execution"
      ],
      "properties": {
        "approval": {
          "type": "boolean",
          "const": false
        },
        "enforcement": {
          "type": "boolean",
          "const": false
        },
        "autonomous_execution": {
          "type": "boolean",
          "const": false
        },
        "runtime_control_plane": {
          "type": "boolean",
          "const": false
        },
        "authority_grant": {
          "type": "boolean",
          "const": false
        },
        "provider_output_authorizes_execution": {
          "type": "boolean",
          "const": false
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "evidence_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "required"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "inspection_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "format",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "enum": [
            "json",
            "markdown"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "review_section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_id",
        "display_name",
        "focus"
      ],
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "focus": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
