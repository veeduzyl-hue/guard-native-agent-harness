{
  "name": "guard-native-agent-harness",
  "version": "0.1.0",
  "description": "Bounded local AI agent harness scaffold for governance-ready evidence packs.",
  "type": "module",
  "private": true,
  "bin": {
    "guard-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "verify:v0.1": "node scripts/verify_v0_1_acceptance.mjs",
    "verify:v0.1:release": "node scripts/verify_v0_1_release_ready.mjs",
    "check:ollama": "node scripts/check_ollama_local.mjs",
    "verify:ollama:e2e": "node scripts/verify_ollama_e2e_local.mjs",
    "verify:openai:planner": "node scripts/verify_openai_planner_local.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/node": "22.10.2",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vitest": "0.34.6"
  },
  "dependencies": {
    "commander": "13.0.0"
  }
}
